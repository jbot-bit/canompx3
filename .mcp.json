{
  "mcpServers": {
    "gold-db": {
      "type": "stdio",
      "command": "python",
      "args": [
        "trading_app/mcp_server.py"
      ],
      "env": {}
    },
    "notebooklm": {
      "type": "stdio",
      "command": "notebooklm-mcp",
      "args": [
        "--config", "notebooklm-config.json",
        "server",
        "--transport", "stdio"
      ],
      "env": {
        "PYTHONIOENCODING": "utf-8"
      }
    }
  }
}