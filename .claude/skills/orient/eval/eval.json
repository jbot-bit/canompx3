{
  "skill": "orient",
  "version": 1,
  "tests": [
    {
      "id": "or-01",
      "prompt": "where are we",
      "assertions": [
        {
          "id": "or-01-a1",
          "type": "regex_match",
          "pattern": "(STAGE_STATE|stage.*none|no active stage)",
          "description": "Checks for active stage state"
        },
        {
          "id": "or-01-a2",
          "type": "regex_match",
          "pattern": "(HANDOFF|handoff)",
          "description": "Reads HANDOFF.md for coordination state"
        },
        {
          "id": "or-01-a3",
          "type": "regex_not_match",
          "pattern": "\\d+ (validated|strategies).*from memory",
          "description": "Does not cite strategy counts from memory"
        },
        {
          "id": "or-01-a4",
          "type": "regex_match",
          "pattern": "(recommend|suggest|next|action|priority)",
          "description": "Provides recommended next action"
        }
      ]
    },
    {
      "id": "or-02",
      "prompt": "what's the project status",
      "assertions": [
        {
          "id": "or-02-a1",
          "type": "regex_match",
          "pattern": "(git log|recent commit|latest commit)",
          "description": "Checks recent git activity"
        },
        {
          "id": "or-02-a2",
          "type": "regex_match",
          "pattern": "(MGC|MNQ|MES)",
          "description": "References active instruments"
        },
        {
          "id": "or-02-a3",
          "type": "regex_not_match",
          "pattern": "(?:active|ACTIVE|deployed|trading|live).*(?:M2K|MCL|SIL|M6E|MBT)|(?:M2K|MCL|SIL|M6E|MBT).*(?:active|ACTIVE|deployed|trading|live)",
          "description": "Does not reference dead instruments as active (mentioning them as dead is fine)"
        },
        {
          "id": "or-02-a4",
          "type": "regex_match",
          "pattern": "(?:action.?queue|next_session_todo|ROADMAP|priority|todo)",
          "description": "References action queue or roadmap for next steps"
        },
        {
          "id": "or-02-a5",
          "type": "regex_match",
          "pattern": "(?:deploy|lane|prop|topstep|account|profile)",
          "description": "References current deployment state"
        }
      ]
    },
    {
      "id": "or-03",
      "prompt": "orient me on the research state",
      "assertions": [
        {
          "id": "or-03-a1",
          "type": "regex_match",
          "pattern": "(?:Blueprint|STRATEGY_BLUEPRINT|NO.?GO|dead)",
          "description": "References Strategy Blueprint for research routing"
        },
        {
          "id": "or-03-a2",
          "type": "regex_match",
          "pattern": "(?:ML.*DEAD|break.?speed|RESURRECTED|validated|124)",
          "description": "Shows awareness of key research findings"
        },
        {
          "id": "or-03-a3",
          "type": "regex_match",
          "pattern": "(?:holdout|2026|sacred|pre.?registered)",
          "description": "References 2026 holdout status"
        },
        {
          "id": "or-03-a4",
          "type": "regex_match",
          "pattern": "(?:memory|pinecone|prior.*finding|research.*history)",
          "description": "Consults project memory for research context"
        }
      ]
    }
  ]
}
