{
  "skill": "verify",
  "version": 1,
  "tests": [
    {
      "id": "vf-01",
      "prompt": "verify",
      "assertions": [
        {
          "id": "vf-01-a1",
          "type": "command_ran",
          "pattern": "check_drift\\.py",
          "description": "Must run drift checks"
        },
        {
          "id": "vf-01-a2",
          "type": "regex_match",
          "pattern": "(PASS|FAIL|pass|fail).*\\d+",
          "description": "Reports pass/fail counts with numbers"
        },
        {
          "id": "vf-01-a3",
          "type": "regex_not_match",
          "pattern": "(should pass|probably|likely|I think)",
          "description": "No hedging — show actual results, not predictions"
        },
        {
          "id": "vf-01-a4",
          "type": "command_ran",
          "pattern": "pytest",
          "description": "Must run tests"
        },
        {
          "id": "vf-01-a5",
          "type": "command_ran",
          "pattern": "(ruff|pyright)",
          "description": "Must run linting or type checking"
        }
      ]
    },
    {
      "id": "vf-02",
      "prompt": "is everything green?",
      "assertions": [
        {
          "id": "vf-02-a1",
          "type": "command_ran",
          "pattern": "check_drift\\.py",
          "description": "Casual phrasing still triggers drift checks"
        },
        {
          "id": "vf-02-a2",
          "type": "regex_match",
          "pattern": "\\d+.*check|check.*\\d+",
          "description": "Reports actual check count"
        },
        {
          "id": "vf-02-a3",
          "type": "text_not_contains",
          "value": "should be fine",
          "description": "No vague reassurances"
        }
      ]
    },
    {
      "id": "vf-03",
      "prompt": "verify done",
      "assertions": [
        {
          "id": "vf-03-a1",
          "type": "command_ran",
          "pattern": "check_drift\\.py",
          "description": "Done mode still runs drift"
        },
        {
          "id": "vf-03-a2",
          "type": "command_ran",
          "pattern": "pytest",
          "description": "Done mode runs tests"
        },
        {
          "id": "vf-03-a3",
          "type": "command_ran",
          "pattern": "ruff",
          "description": "Done mode runs linting"
        },
        {
          "id": "vf-03-a4",
          "type": "regex_match",
          "pattern": "STAGE_STATE|stage",
          "description": "Done mode checks stage state"
        }
      ]
    }
  ]
}
