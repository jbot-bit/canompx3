# .aiderignore — negation-allowlist for aider context.
#
# Aider treats this file like .gitignore (gitignore-with-negation). The default
# stance is "exclude everything" via the leading `*`, then allow back only the
# files we want the coding agent to see. This keeps token budgets bounded and
# prevents accidental ingestion of databases, parquet files, or vendor caches.
#
# Hard rule: never allow data files, database files, venvs, worktrees, or
# generated artifacts. The agent edits source code only; it reads the
# canonical doctrine to ground decisions.

# Default-deny everything.
*

# --- Source code (allow back) ---
!pipeline/**/*.py
!trading_app/**/*.py
!scripts/tools/**/*.py
!tests/**/*.py

# --- Doctrine (allow back) ---
!CLAUDE.md
!CONVENTIONS.md
!TRADING_RULES.md
!RESEARCH_RULES.md
!ROADMAP.md
!HANDOFF.md
!REPO_MAP.md
!AGENTS.md
!docs/governance/**/*.md
!docs/specs/**/*.md
!docs/institutional/**/*.md
!docs/STRATEGY_BLUEPRINT.md
!.claude/rules/**/*.md

# --- Project config (allow back; small, load-bearing) ---
!pyproject.toml
!ruff.toml
!pyrightconfig.json
!.python-version
!constraints.txt

# --- Hard exclusions (never allow back) ---
gold.db
*.db
*.duckdb
*.parquet
*.csv
*.tsv
*.feather
*.pkl
*.pickle
data/
.venv/
.venv-wsl/
venv/
.worktrees/
node_modules/
__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/
.mypy_cache/

# --- Aider history files ---
.aider*
