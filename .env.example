DATABENTO_API_KEY=db-your-key-here
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Broker selection — projectx (TopStep/TopstepX), tradovate, rithmic
BROKER=projectx

# ProjectX / TopstepX API (live trading)
# TopStep Combine accounts use base URL https://api.topstepx.com
PROJECTX_USERNAME=your-projectx-username
PROJECTX_API_KEY=your-projectx-api-key
PROJECTX_BASE_URL=https://api.topstepx.com

# Tradovate (Tradeify / Topstep legacy) — only if BROKER=tradovate
# TRADOVATE_USER=
# TRADOVATE_PASS=
# TRADOVATE_APP_ID=
# TRADOVATE_APP_VERSION=
# TRADOVATE_CID=
# TRADOVATE_SEC=

# Telegram alerts (required for live mode — bot fails closed without working notifications)
TELEGRAM_BOT_TOKEN=your-bot-id:your-token-here
TELEGRAM_CHAT_ID=your-chat-id-here

# OpenRouter / DeepSeek research profiles
OPENROUTER_API_KEY=sk-or-your-key-here

# Configure exact OpenRouter model IDs explicitly. The repo does not silently
# pick a model for you.
# CANOMPX3_AI_DEEPSEEK_PLANNING_MODEL=deepseek/deepseek-v4-pro
# CANOMPX3_AI_DEEPSEEK_RESEARCH_LONG_CONTEXT_MODEL=deepseek/deepseek-v4-pro
# CANOMPX3_AI_DEEPSEEK_STRUCTURED_EXTRACTION_MODEL=deepseek/deepseek-v4-flash

# Optional provider-order overrides for OpenRouter-backed research profiles.
# Safety defaults remain fail-closed and cannot be weakened via env.
# CANOMPX3_AI_DEEPSEEK_PLANNING_PROVIDER_ORDER=deepseek
# CANOMPX3_AI_DEEPSEEK_RESEARCH_LONG_CONTEXT_PROVIDER_ORDER=deepseek
# CANOMPX3_AI_DEEPSEEK_STRUCTURED_EXTRACTION_PROVIDER_ORDER=deepseek
