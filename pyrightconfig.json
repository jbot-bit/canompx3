{
    "pythonVersion": "3.13",
    "typeCheckingMode": "basic",
    "extraPaths": ["."],
    "venvPath": ".",
    "venv": ".venv",
    "include": [
        "pipeline",
        "trading_app",
        "ui"
    ],
    "exclude": [
        "**/__pycache__",
        "venv",
        ".venv",
        "research",
        "openclaw",
        "llm-code-scanner",
        ".auto-claude"
    ],
    "reportMissingModuleSource": "warning",
    "reportMissingTypeStubs": "warning",
    "reportUnusedImport": false,
    "reportUnusedVariable": false
}
