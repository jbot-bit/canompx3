#!/usr/bin/env bash
#
# Pre-push hook: full-drift safety gate.
#
# WHY THIS EXISTS (2026-06-05, branch drift-supersonic):
# The pre-COMMIT hook path-scopes its drift step — a docs-only commit (markdown/
# notes, no code/config) skips the ~172s full drift check for speed. That skip is
# only SOUND if the full blocking drift set is GUARANTEED to run before the work
# leaves this machine. This hook is that guarantee: every `git push` runs the FULL
# drift set (no --skip flags, unlike pre-commit) and aborts the push on any drift.
# CI (.github/workflows/ci.yml) is the second backstop.
#
# Fail-closed: if drift fails, the push is blocked. A genuine tooling error (no
# python, etc.) also blocks — at push time, refusing to push unverified work is
# the safe default. (Contrast: pre-commit's lock/CRG steps fail OPEN because a
# wedged commit is worse than a missed advisory; a push is a deliberate, less
# frequent act where the conservative default is correct.)
#
# Setup: git config core.hooksPath .githooks  (already set for this repo)
# Bypass (use sparingly, e.g. pushing a docs-only backup branch): git push --no-verify

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
_SAVED_PATH="$PATH"

case "$(uname -s 2>/dev/null || echo unknown)" in
    MINGW*|MSYS*|CYGWIN*) IS_WINDOWS_SHELL=1 ;;
    *) IS_WINDOWS_SHELL=0 ;;
esac

# Activate venv (same precedence as pre-commit: WSL venv, then .venv, then legacy).
if [ "$IS_WINDOWS_SHELL" -eq 0 ] && [ -f "$SCRIPT_DIR/.venv-wsl/bin/activate" ]; then
    source "$SCRIPT_DIR/.venv-wsl/bin/activate" 2>/dev/null
elif [ "$IS_WINDOWS_SHELL" -eq 0 ] && [ -f "$SCRIPT_DIR/.venv/bin/activate" ]; then
    source "$SCRIPT_DIR/.venv/bin/activate" 2>/dev/null
elif [ "$IS_WINDOWS_SHELL" -eq 1 ] && [ -f "$SCRIPT_DIR/.venv/Scripts/activate" ]; then
    source "$SCRIPT_DIR/.venv/Scripts/activate" 2>/dev/null
elif [ "$IS_WINDOWS_SHELL" -eq 1 ] && [ -f "$SCRIPT_DIR/venv/Scripts/activate" ]; then
    source "$SCRIPT_DIR/venv/Scripts/activate" 2>/dev/null
elif [ "$IS_WINDOWS_SHELL" -eq 0 ] && [ -f "$SCRIPT_DIR/venv/bin/activate" ]; then
    source "$SCRIPT_DIR/venv/bin/activate" 2>/dev/null
fi
export PATH="$PATH:$_SAVED_PATH"

# Resolve python — same precedence/cross-wire guards as pre-commit (lines 239-265):
# prefer SCRIPT_DIR/.venv (uv-managed, isolated per worktree), then the canonical
# sibling venv (legacy shared-venv worktrees), then legacy venv, then PATH python.
PARENT_DIR="$(dirname "$SCRIPT_DIR")"
WORKTREE_BASENAME="$(basename "$SCRIPT_DIR")"
CANONICAL_BASENAME="${WORKTREE_BASENAME%%-*}"
CANONICAL_VENV_PY=""
for candidate in \
    "$PARENT_DIR/$CANONICAL_BASENAME/.venv-wsl/bin/python" \
    "$PARENT_DIR/$CANONICAL_BASENAME/.venv/bin/python" \
    "$PARENT_DIR/$CANONICAL_BASENAME/.venv/Scripts/python.exe" ; do
    if [ "$IS_WINDOWS_SHELL" -eq 0 ] && [[ "$candidate" == *"/Scripts/"* ]]; then
        continue
    fi
    if [ "$IS_WINDOWS_SHELL" -eq 1 ] && [[ "$candidate" == *"/.venv-wsl/"* ]]; then
        continue
    fi
    if [ -f "$candidate" ]; then
        CANONICAL_VENV_PY="$candidate"
        break
    fi
done

PYTHON="python"
if [ "$IS_WINDOWS_SHELL" -eq 0 ] && [ -f "$SCRIPT_DIR/.venv-wsl/bin/python" ]; then
    PYTHON="$SCRIPT_DIR/.venv-wsl/bin/python"
elif [ "$IS_WINDOWS_SHELL" -eq 0 ] && [ -f "$SCRIPT_DIR/.venv/bin/python" ]; then
    PYTHON="$SCRIPT_DIR/.venv/bin/python"
elif [ "$IS_WINDOWS_SHELL" -eq 1 ] && [ -f "$SCRIPT_DIR/.venv/Scripts/python.exe" ]; then
    PYTHON="$SCRIPT_DIR/.venv/Scripts/python.exe"
elif [ -n "$CANONICAL_VENV_PY" ] && [ -f "$CANONICAL_VENV_PY" ]; then
    PYTHON="$CANONICAL_VENV_PY"
elif [ "$IS_WINDOWS_SHELL" -eq 1 ] && [ -f "$SCRIPT_DIR/venv/Scripts/python.exe" ]; then
    PYTHON="$SCRIPT_DIR/venv/Scripts/python.exe"
elif [ "$IS_WINDOWS_SHELL" -eq 0 ] && [ -f "$SCRIPT_DIR/venv/bin/python" ]; then
    PYTHON="$SCRIPT_DIR/venv/bin/python"
fi

# Robust fallback (kills the exit-127 class). When this hook fires from a
# WORKTREE (operator launches via start_worktree) or from an odd CWD, SCRIPT_DIR
# points at a tree with no .venv, and the canonical-sibling probe above can miss
# (its $PARENT_DIR/$CANONICAL_BASENAME name heuristic doesn't match every
# worktree naming). PYTHON then stays the literal "python" default, which is NOT
# on git's stripped push PATH -> the drift step below returns 127, MISREPORTED
# as "drift failed". `git rev-parse --show-toplevel` resolves the canonical
# checkout root from ANY worktree or CWD, so the real venv is found regardless
# of launch context. This is the launch-context-agnostic fix (the operator does
# not always push from a worktree).
if [ "$PYTHON" = "python" ]; then
    REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || echo "")"
    if [ -n "$REPO_ROOT" ]; then
        if [ "$IS_WINDOWS_SHELL" -eq 1 ] && [ -f "$REPO_ROOT/.venv/Scripts/python.exe" ]; then
            PYTHON="$REPO_ROOT/.venv/Scripts/python.exe"
        elif [ "$IS_WINDOWS_SHELL" -eq 0 ] && [ -f "$REPO_ROOT/.venv-wsl/bin/python" ]; then
            PYTHON="$REPO_ROOT/.venv-wsl/bin/python"
        elif [ "$IS_WINDOWS_SHELL" -eq 0 ] && [ -f "$REPO_ROOT/.venv/bin/python" ]; then
            PYTHON="$REPO_ROOT/.venv/bin/python"
        fi
    fi
fi

if [ "$IS_WINDOWS_SHELL" -eq 0 ] && [[ "$PYTHON" == *"/Scripts/"* || "$PYTHON" == *.exe ]]; then
    echo "BLOCKED (pre-push): POSIX/WSL selected Windows Python: $PYTHON"
    echo "         Use .venv-wsl/bin/python in WSL/Linux; do not cross-wire .venv/Scripts."
    exit 1
fi
if [ "$IS_WINDOWS_SHELL" -eq 1 ] && [[ "$PYTHON" == *"/.venv-wsl/"* ]]; then
    echo "BLOCKED (pre-push): Windows selected WSL Python: $PYTHON"
    echo "         Use .venv/Scripts/python.exe on Windows; do not cross-wire .venv-wsl."
    exit 1
fi

# 0-serialize. Push serialization — the push-side twin of pre-commit step 0.
# The drift gate below takes ~3 min; two terminals pushing HEAD:main at once
# each run that full gate and the loser hits `cannot lock ref 'refs/heads/main'`,
# throwing away ~3 min of drift. We acquire an O_EXCL lock for the duration of
# THIS hook (released via trap on any exit, incl. set -e abort mid-drift) so the
# expensive window is serial. A 2nd concurrent push detects the live lock and
# exits INSTANTLY here, BEFORE wasting any drift. Reuses the canonical
# commit_serialize.py helper with a distinct lock name — no re-encoding.
# Fail-OPEN: if the helper errors it exits 0 (allow) — a serializer must never
# wedge a legitimate push; the drift gate below is the real (fail-closed) net.
# Use PATH python for this early step (stdlib-only helper), same as pre-commit.
PUSH_LOCK_PY="python"
[ -x "$SCRIPT_DIR/.venv-wsl/bin/python" ] && [ "$IS_WINDOWS_SHELL" -eq 0 ] && PUSH_LOCK_PY="$SCRIPT_DIR/.venv-wsl/bin/python"
[ "$PUSH_LOCK_PY" = "python" ] && [ -x "$SCRIPT_DIR/.venv/bin/python" ] && PUSH_LOCK_PY="$SCRIPT_DIR/.venv/bin/python"
[ -x "$SCRIPT_DIR/.venv/Scripts/python.exe" ] && [ "$IS_WINDOWS_SHELL" -eq 1 ] && PUSH_LOCK_PY="$SCRIPT_DIR/.venv/Scripts/python.exe"
# Native pid of THIS shell (lives for the whole 3-min gate) — the serializer's
# real liveness key, so a 2nd push BLOCKS while this one runs and only steals
# once this shell exits. /proc/$$/winpid on Git Bash; $$ on POSIX (already native).
CANOMPX3_HOOK_NATIVE_PID="$(cat /proc/$$/winpid 2>/dev/null || echo $$)"
export CANOMPX3_HOOK_NATIVE_PID
export CANOMPX3_PRECOMMIT_LOCK_OWNER="push:$$"
set +e
"$PUSH_LOCK_PY" "$SCRIPT_DIR/scripts/tools/commit_serialize.py" acquire .push-in-progress.lock
PUSH_LOCK_RC=$?
set -e
if [ "$PUSH_LOCK_RC" -ne 0 ]; then
    # Helper already printed a structured BLOCKED message to stderr.
    exit 1
fi
# Release the push lock on any exit (success, drift failure, or set -e abort).
trap '"$PUSH_LOCK_PY" "$SCRIPT_DIR/scripts/tools/commit_serialize.py" release .push-in-progress.lock >/dev/null 2>&1 || true' EXIT

echo "=== PRE-PUSH: full drift safety gate ==="
echo "  (full blocking drift set — the net for pre-commit's path-scoped skip)"

# Honest interpreter gate. If $PYTHON still doesn't actually execute (every probe
# above missed AND the git-toplevel fallback couldn't find a venv), STOP here
# with a CLEAR message — do NOT let the drift step below return 127 and get
# misreported as "drift failed (exit $DRIFT_EXIT)". A resolver miss is an
# environment problem, not a drift violation; conflating them is what made the
# original exit-127 so confusing. Fail-closed: a push without a working
# interpreter is still blocked (refusing to push unverified work is the safe
# default at push time).
if ! "$PYTHON" --version >/dev/null 2>&1; then
    echo ""
    echo "BLOCKED (pre-push): python interpreter not found — cannot run the drift gate."
    echo "  Resolved PYTHON=$PYTHON (does not execute under git's push environment)."
    echo "  This is an ENVIRONMENT problem (no venv on PATH / not found from this"
    echo "  worktree), NOT a drift failure. Expected venv: <repo>/.venv/Scripts/python.exe"
    echo "  (Windows) or <repo>/.venv-wsl/bin/python (WSL). Re-run the push from a"
    echo "  shell where the repo venv resolves, or (last resort, drift proven green"
    echo "  by hand) authorized: git push --no-verify"
    exit 1
fi

# Run the FULL drift set. No --skip-crg-advisory / --skip-advisory here: pre-push
# is the place we pay for complete coverage, because a docs-only commit may have
# skipped drift entirely at commit time. Show only the salient lines (mirror the
# pre-commit awk filter) so a clean run is quiet and a failure is legible.
DRIFT_TMPFILE=$(mktemp)
set +e
"$PYTHON" "$SCRIPT_DIR/pipeline/check_drift.py" 2>&1 | tee "$DRIFT_TMPFILE" | awk '
    /^python-dotenv could not parse statement starting at line / { next }
    /^Check [0-9]+:/ || /^  FAILED:/ || /^  WARNING:/ || /^  SKIPPED/ || /^DRIFT / || /^NO DRIFT/ || /^====/ { print }
'
DRIFT_EXIT=${PIPESTATUS[0]}
set -e
rm -f "$DRIFT_TMPFILE"

if [ "$DRIFT_EXIT" -ne 0 ]; then
    echo ""
    echo "BLOCKED (pre-push): full drift failed (exit $DRIFT_EXIT) — push aborted."
    echo "  This is the safety net for commit-time path-scoped drift skipping."
    echo "  Fix drift, or (docs-only backup branch only) re-run with: git push --no-verify"
    exit 1
fi

echo "=== PRE-PUSH: full drift PASSED — push allowed ==="
exit 0
