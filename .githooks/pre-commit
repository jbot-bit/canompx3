#!/usr/bin/env bash
#
# Pre-commit hook: blocks commit if guardrails fail.
# Staged-file-aware: only tests relevant to what changed. Fail-closed.
# Setup: git config core.hooksPath .githooks
#

set -e

# Activate venv if present (for ruff/python/pytest)
# .venv/ is the canonical venv (managed by uv). venv/ is legacy fallback.
# Save PATH before activate to prevent Git Bash utilities from disappearing
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
_SAVED_PATH="$PATH"
if [ -f "$SCRIPT_DIR/.venv/Scripts/activate" ]; then
    source "$SCRIPT_DIR/.venv/Scripts/activate" 2>/dev/null
elif [ -f "$SCRIPT_DIR/.venv/bin/activate" ]; then
    source "$SCRIPT_DIR/.venv/bin/activate" 2>/dev/null
elif [ -f "$SCRIPT_DIR/venv/Scripts/activate" ]; then
    source "$SCRIPT_DIR/venv/Scripts/activate" 2>/dev/null
elif [ -f "$SCRIPT_DIR/venv/bin/activate" ]; then
    source "$SCRIPT_DIR/venv/bin/activate" 2>/dev/null
fi
# Restore Git Bash utilities (tail, grep, etc.) that activate may have removed
export PATH="$PATH:$_SAVED_PATH"

echo "=== PRE-COMMIT CHECKS ==="
echo ""

# 0c. Branch-flip guard — abort if HEAD branch != branch_at_start in session lock.
# A mid-session `git checkout <other-branch>` would deposit this commit on the
# wrong branch. Catch it here before any work is staged.
GIT_DIR_PATH=$(git rev-parse --git-dir 2>/dev/null || true)
if [ -n "$GIT_DIR_PATH" ] && [ -f "$GIT_DIR_PATH/.claude.pid" ]; then
    BRANCH_AT_START=$(python -c "
import json, sys
try:
    d = json.load(open('$GIT_DIR_PATH/.claude.pid'))
    print(d.get('branch_at_start', ''))
except Exception:
    pass
" 2>/dev/null || true)
    CURRENT_BRANCH=$(git branch --show-current 2>/dev/null || true)
    if [ -n "$BRANCH_AT_START" ] && [ -n "$CURRENT_BRANCH" ] && [ "$BRANCH_AT_START" != "$CURRENT_BRANCH" ]; then
        echo "BLOCKED: Branch changed mid-session."
        echo "  Session started on: $BRANCH_AT_START"
        echo "  Current branch:     $CURRENT_BRANCH"
        echo "  This commit would land on the wrong branch."
        echo "  Fix: git checkout $BRANCH_AT_START  OR  rm '$GIT_DIR_PATH/.claude.pid' and restart"
        exit 1
    fi
fi

# Quick venv health — catches dev deps wiped by interrupted uv sync
if ! "$SCRIPT_DIR/.venv/Scripts/python.exe" -c "import pytest, httpx" 2>/dev/null && \
   ! "$SCRIPT_DIR/.venv/bin/python" -c "import pytest, httpx" 2>/dev/null; then
    echo "BLOCKED: Dev deps missing (pytest/httpx). Run: uv pip install pytest pytest-asyncio pytest-cov httpx ruff pyright pip-audit"
    exit 1
fi

# Resolve python — prefer .venv/ (uv-managed), fall back to venv/ (legacy)
PYTHON="python"
if [ -f "$SCRIPT_DIR/.venv/Scripts/python.exe" ]; then
    PYTHON="$SCRIPT_DIR/.venv/Scripts/python.exe"
elif [ -f "$SCRIPT_DIR/.venv/bin/python" ]; then
    PYTHON="$SCRIPT_DIR/.venv/bin/python"
elif [ -f "$SCRIPT_DIR/venv/Scripts/python.exe" ]; then
    PYTHON="$SCRIPT_DIR/venv/Scripts/python.exe"
elif [ -f "$SCRIPT_DIR/venv/bin/python" ]; then
    PYTHON="$SCRIPT_DIR/venv/bin/python"
fi

# 0a. Auto-stage HANDOFF.md if dirty (picks up post-commit hook's auto-update)
if git diff --name-only -- HANDOFF.md 2>/dev/null | grep -q 'HANDOFF.md'; then
    git add HANDOFF.md
fi

# 0b. Auto-normalize line endings — prevents CRLF reintroduction.
# Detects any staged text file with CRLF in the staged blob, renormalizes to LF
# per .gitattributes (eol=lf), and re-stages. Silent fix unless something was
# actually normalized. This automates away the recurring "stash@{N}: pre-rebase
# CRLF noise" pattern that has cost multiple sessions.
STAGED_TEXT=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null)
if [ -n "$STAGED_TEXT" ]; then
    NORMALIZED_FILES=""
    while IFS= read -r f; do
        [ -z "$f" ] && continue
        attr=$(git check-attr text -- "$f" 2>/dev/null)
        case "$attr" in
            *": text: set"*|*": text: auto"*)
                if git show ":$f" 2>/dev/null | grep -lU $'\r$' >/dev/null 2>&1; then
                    git add --renormalize -- "$f" 2>/dev/null
                    NORMALIZED_FILES="$NORMALIZED_FILES$f
"
                fi
                ;;
        esac
    done <<INNER_EOF
$STAGED_TEXT
INNER_EOF
    if [ -n "$NORMALIZED_FILES" ]; then
        echo "[0b] Auto-renormalized CRLF->LF in staged blobs (per .gitattributes eol=lf):"
        printf "  %s" "$NORMALIZED_FILES" | sed 's/^/  /'
    fi
fi


# 1. Ruff lint check (~1 second)
echo "[1/8] Ruff lint..."
RUFF="ruff"
if [ -f "$SCRIPT_DIR/.venv/Scripts/ruff.exe" ]; then
    RUFF="$SCRIPT_DIR/.venv/Scripts/ruff.exe"
elif [ -f "$SCRIPT_DIR/venv/Scripts/ruff.exe" ]; then
    RUFF="$SCRIPT_DIR/venv/Scripts/ruff.exe"
fi
if ! "$RUFF" check pipeline/ trading_app/ scripts/ > /dev/null 2>&1; then
    echo "BLOCKED: Lint errors detected."
    "$RUFF" check pipeline/ trading_app/ scripts/
    exit 1
fi
echo "  PASSED"

# 2. Ruff format check — auto-fix and re-stage if needed (~1 second)
echo "[2/8] Ruff format..."
if ! "$RUFF" format --check pipeline/ trading_app/ scripts/ tests/ > /dev/null 2>&1; then
    echo "  Auto-formatting..."
    "$RUFF" format pipeline/ trading_app/ scripts/ tests/ > /dev/null 2>&1
    # Re-stage only the files that were already staged (don't add new files).
    # Use `-f` unconditionally: every file in STAGED_FOR_FMT was already staged
    # for this commit, so we KNOW it should be added — `-f` only suppresses the
    # "path is ignored" warning that fires for paths under whitelisted-but-
    # globally-ignored dirs (e.g. `.claude/hooks/*.py` whitelisted via
    # `!.claude/hooks/` in `.gitignore`). Without `-f` here, ruff-formatting
    # such a file leaves the format diff in the working tree post-commit
    # (real incident: PR #141 first attempt). `git check-ignore` returns
    # "not ignored" for those paths but `git add` still warns + exits 1 —
    # so the prior `if check-ignore; then -f; else plain` branching couldn't
    # detect the case. Forcing `-f` for all already-staged files is safe
    # because the diff-filter restricts us to files git is already tracking.
    STAGED_FOR_FMT=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$' || true)
    if [ -n "$STAGED_FOR_FMT" ]; then
        while IFS= read -r staged_file; do
            [ -z "$staged_file" ] && continue
            git add -f -- "$staged_file"
        done <<EOF
$STAGED_FOR_FMT
EOF
    fi
    echo "  Auto-formatted and re-staged"
fi
echo "  PASSED"

# 3. Drift check (~2 seconds)
# Commit-time coverage must remain the FULL drift set. The post-edit hook's
# debounce file only suppresses repeated FAST drift runs while editing; it must
# never suppress the full commit-time gate, or slow-check regressions can slip
# through unnoticed.
echo "[3/8] Drift check..."
if ! "$PYTHON" pipeline/check_drift.py > /dev/null 2>&1; then
    echo "BLOCKED: Drift detected."
    "$PYTHON" pipeline/check_drift.py 2>&1 | awk '
        /^Check .*\.\.\.$/ { header=$0; next }
        /^  FAILED:/ { if (header) { print header; header="" } print; infail=1; next }
        infail && NF==0 { infail=0; next }
        infail { print; next }
        /^====/ || /^DRIFT / || /^NO DRIFT/ { print }
    '
    exit 1
else
    echo "  PASSED"
fi

# 3b. CRG incremental update (advisory-only, fail-open, ~1-5s)
# Keeps the graph DB fresh so drift checks D1-D5 (Phase 2) and slash
# commands see the committed state. Idempotent on top of the PostToolUse
# hook (F3); defends against PostToolUse misses on fast edits.
echo "[3b/8] CRG update..."
if command -v code-review-graph >/dev/null 2>&1; then
    if ! code-review-graph update --base origin/main > /dev/null 2>&1; then
        echo "  ADVISORY: CRG update failed — graph may be stale (non-blocking)"
    else
        echo "  PASSED"
    fi
else
    echo "  SKIP: code-review-graph not in PATH"
fi

# 4. Staged-file-aware FAST tests — pre-commit must finish in <30s.
#    - pipeline/ changes  → tests/test_pipeline/ (~11s, 636 tests)
#    - trading_app/ changes → fast subset only (~2s, config/entry/tripwires)
#    - Both changed → pipeline/ + fast trading_app subset (~13s)
#    - tests/ files staged → run only those test files
#    - scripts/ or docs/ changes → skip pytest (not production code)
#    Full trading_app suite (13 min) runs via `pytest` or CI, not pre-commit.
#
# NOTE: Capture output to temp file, NOT command substitution — PIPESTATUS is
# unreliable in Git Bash command substitutions and can silently return 0.
echo "[4/8] Fast tests..."
STAGED_ALL=$(git diff --cached --name-only --diff-filter=ACM)
STAGED_PIPELINE=$(echo "$STAGED_ALL" | grep '^pipeline/' | grep '\.py$' || true)
STAGED_TRADING=$(echo "$STAGED_ALL"  | grep '^trading_app/' | grep '\.py$' || true)
STAGED_TESTS=$(echo "$STAGED_ALL"    | grep '^tests/' | grep '\.py$' || true)

# Fast trading_app tests — core invariants without the 13-min heavy suite
FAST_TRADING="$SCRIPT_DIR/tests/test_trading_app/test_config.py \
$SCRIPT_DIR/tests/test_trading_app/test_live_config.py \
$SCRIPT_DIR/tests/test_trading_app/test_entry_rules.py \
$SCRIPT_DIR/tests/test_trading_app/test_market_state.py \
$SCRIPT_DIR/tests/test_pipeline/test_tripwires.py"

# Build the test target list
TEST_ARGS=""
if [ -n "$STAGED_TESTS" ]; then
    # Staged test files: run only those
    TEST_ARGS="$STAGED_TESTS"
elif [ -n "$STAGED_PIPELINE" ] && [ -z "$STAGED_TRADING" ]; then
    TEST_ARGS="$SCRIPT_DIR/tests/test_pipeline/"
elif [ -n "$STAGED_TRADING" ] && [ -z "$STAGED_PIPELINE" ]; then
    TEST_ARGS="$FAST_TRADING"
elif [ -n "$STAGED_PIPELINE" ] && [ -n "$STAGED_TRADING" ]; then
    TEST_ARGS="$SCRIPT_DIR/tests/test_pipeline/ $FAST_TRADING"
fi

if [ -z "$TEST_ARGS" ]; then
    echo "  No production .py files staged — tests skipped"
else
    TEST_TMPFILE=$(mktemp)
    set +e
    # Scrub git env vars that the commit hook inherits — they leak into test
    # subprocesses (e.g. tests calling `git worktree list` from a tmp_path)
    # and make those calls report the parent repo's worktrees instead of
    # erroring on the empty tmp_path. See PR #126 postmortem.
    # shellcheck disable=SC2086  # intentional word-splitting for TEST_ARGS
    env -u GIT_DIR -u GIT_WORK_TREE -u GIT_INDEX_FILE \
        "$PYTHON" -m pytest $TEST_ARGS -x -q > "$TEST_TMPFILE" 2>&1
    TEST_EXIT=$?
    set -e
    tail -5 "$TEST_TMPFILE"
    rm -f "$TEST_TMPFILE"
    if [ "$TEST_EXIT" -ne 0 ]; then
        echo "BLOCKED: Tests failed."
        exit 1
    fi
fi

# 5. Checkpoint guard (~1 second)
echo "[5/8] Checkpoint guard..."
if ! "$PYTHON" scripts/tools/checkpoint_guard.py > /tmp/canompx3-checkpoint-guard.txt 2>&1; then
    echo "BLOCKED: Checkpoint guard failed."
    cat /tmp/canompx3-checkpoint-guard.txt
    rm -f /tmp/canompx3-checkpoint-guard.txt
    exit 1
fi
rm -f /tmp/canompx3-checkpoint-guard.txt
echo "  PASSED"

# 6. Behavioral audit (~1 second)
echo "[6/8] Behavioral audit..."
if ! "$PYTHON" scripts/tools/audit_behavioral.py > /dev/null 2>&1; then
    echo "BLOCKED: Behavioral audit violations detected."
    "$PYTHON" scripts/tools/audit_behavioral.py
    exit 1
fi
echo "  PASSED"

# 7. Claim hygiene for staged result docs (~sub-second)
echo "[7/8] Claim hygiene..."
STAGED_RESULT_DOCS=$(echo "$STAGED_ALL" | grep '^docs/audit/results/.*\.md$' || true)
if [ -z "$STAGED_RESULT_DOCS" ]; then
    echo "  No staged result docs"
else
    RESULT_DOC_ARGS=()
    while IFS= read -r staged_file; do
        [ -z "$staged_file" ] && continue
        RESULT_DOC_ARGS+=("$staged_file")
    done <<EOF
$STAGED_RESULT_DOCS
EOF
    CLAIM_TMPFILE=$(mktemp)
    set +e
    "$PYTHON" scripts/tools/check_claim_hygiene.py "${RESULT_DOC_ARGS[@]}" > "$CLAIM_TMPFILE" 2>&1
    CLAIM_EXIT=$?
    set -e
    if [ "$CLAIM_EXIT" -ne 0 ]; then
        echo "BLOCKED: Claim hygiene check failed."
        cat "$CLAIM_TMPFILE"
        rm -f "$CLAIM_TMPFILE"
        exit 1
    fi
    rm -f "$CLAIM_TMPFILE"
    echo "  PASSED"
fi

# 8. Syntax check on staged .py files
echo "[8/8] Syntax check..."
STAGED_PY=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$' || true)
if [ -n "$STAGED_PY" ]; then
    for f in $STAGED_PY; do
        "$PYTHON" -m py_compile "$f" 2>/dev/null
        if [ $? -ne 0 ]; then
            echo "BLOCKED: Syntax error in $f"
            "$PYTHON" -m py_compile "$f"
            exit 1
        fi
    done
    echo "  PASSED"
else
    echo "  No .py files staged"
fi

echo ""
echo "=== ALL PRE-COMMIT CHECKS PASSED ==="
