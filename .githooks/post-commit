#!/usr/bin/env bash
#
# Post-commit hook: auto-updates HANDOFF.md so nobody has to remember.
# Writes the Last Session block with tool, date, SHA, summary, and files changed.
#
# This is ADVISORY — if it fails, the commit is already done. Never exit 1.
#

# Skip during rebase, merge, or cherry-pick (fires per replayed commit = spam).
#
# Resolve the REAL git-dir at runtime. In a git worktree the git-dir is
# `.git/worktrees/<name>/`, NOT a literal `.git/` — so testing `.git/MERGE_HEAD`
# etc. is ALWAYS false in a worktree, the skip never fires, and the HANDOFF
# stamp below re-dirties the tree mid-cherry-pick → the next replayed commit
# aborts ("local changes would be overwritten"). Resolving via rev-parse makes
# this guard fire correctly in both the main checkout and every worktree.
# Fail-open: if rev-parse fails, GIT_DIR stays empty and the path tests below
# are harmless no-ops (no false skip, no crash).
GIT_DIR_RESOLVED=$(git rev-parse --git-dir 2>/dev/null || echo "")
if [ -n "$GIT_REBASE_TODO" ] \
   || { [ -n "$GIT_DIR_RESOLVED" ] && { [ -d "$GIT_DIR_RESOLVED/rebase-merge" ] \
        || [ -d "$GIT_DIR_RESOLVED/rebase-apply" ] || [ -f "$GIT_DIR_RESOLVED/MERGE_HEAD" ] \
        || [ -f "$GIT_DIR_RESOLVED/CHERRY_PICK_HEAD" ]; }; }; then
    exit 0
fi

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
HANDOFF="$SCRIPT_DIR/HANDOFF.md"

if [ ! -f "$HANDOFF" ]; then
    exit 0
fi

# Detect which tool is committing
if [ -n "$CLAUDECODE" ]; then
    TOOL="Claude Code"
elif [ -n "$CODEX_CLI" ] || [ -n "$CODEX" ]; then
    TOOL="Codex"
else
    if grep -qi "wsl" /proc/version 2>/dev/null; then
        TOOL="Codex (WSL)"
    else
        TOOL="Unknown"
    fi
fi

TODAY=$(date +%Y-%m-%d)
SHA=$(git rev-parse --short HEAD 2>/dev/null || echo "unknown")
SUBJECT=$(git log -1 --pretty=format:'%s' 2>/dev/null || echo "unknown")

# Files changed in this commit (compact list)
FILES_CHANGED=$(git diff-tree --no-commit-id --name-only -r HEAD 2>/dev/null | head -20)
FILE_COUNT=$(echo "$FILES_CHANGED" | grep -c '.' 2>/dev/null || echo "0")

# Build the new Last Session block
NEW_SESSION="## Last Session
- **Tool:** ${TOOL}
- **Date:** ${TODAY}
- **Commit:** ${SHA} — ${SUBJECT}
- **Files changed:** ${FILE_COUNT} files"

# Use python for reliable cross-platform multiline replacement
PYTHON="python"
case "$(uname -s 2>/dev/null || echo unknown)" in
    MINGW*|MSYS*|CYGWIN*) IS_WINDOWS_SHELL=1 ;;
    *) IS_WINDOWS_SHELL=0 ;;
esac
if [ "$IS_WINDOWS_SHELL" -eq 0 ] && [ -f "$SCRIPT_DIR/.venv-wsl/bin/python" ]; then
    PYTHON="$SCRIPT_DIR/.venv-wsl/bin/python"
elif [ "$IS_WINDOWS_SHELL" -eq 0 ] && [ -f "$SCRIPT_DIR/.venv/bin/python" ]; then
    PYTHON="$SCRIPT_DIR/.venv/bin/python"
elif [ "$IS_WINDOWS_SHELL" -eq 1 ] && [ -f "$SCRIPT_DIR/.venv/Scripts/python.exe" ]; then
    PYTHON="$SCRIPT_DIR/.venv/Scripts/python.exe"
fi
if [ "$IS_WINDOWS_SHELL" -eq 0 ] && [[ "$PYTHON" == *"/Scripts/"* || "$PYTHON" == *.exe ]]; then
    exit 0
fi
if [ "$IS_WINDOWS_SHELL" -eq 1 ] && [[ "$PYTHON" == *"/.venv-wsl/"* ]]; then
    exit 0
fi

"$PYTHON" -c "
import re, sys

handoff_path = sys.argv[1]
new_block = sys.argv[2]
files_list = sys.argv[3]

with open(handoff_path, 'r', encoding='utf-8') as f:
    content = f.read()

# Build full replacement block
file_lines = [l for l in files_list.strip().splitlines() if l.strip()]
if file_lines:
    detail = '\n'.join(f'  - \`{f}\`' for f in file_lines[:15])
    if len(file_lines) > 15:
        detail += f'\n  - ... and {len(file_lines) - 15} more'
    replacement = new_block + '\n' + detail + '\n'
else:
    replacement = new_block + '\n'

# Replace the Last Session section (up to next ## heading)
pattern = r'## Last Session\n.*?(?=\n## (?!Last Session))'
match = re.search(pattern, content, re.DOTALL)
if match:
    content = content[:match.start()] + replacement + content[match.end():]
    with open(handoff_path, 'w', encoding='utf-8', newline='\n') as f:
        f.write(content)
# If no match, do nothing — don't guess where to insert
" "$HANDOFF" "$NEW_SESSION" "$FILES_CHANGED" 2>/dev/null || true

# -----------------------------------------------------------------------------
# Pinecone auto-sync (NUGGET 1).
#
# Trigger when the just-landed commit touches knowledge-base paths:
#   - docs/audit/results/        (research verdicts)
#   - docs/institutional/literature/  (literature extracts)
#   - docs/runtime/debt-ledger.md     (debt state)
#   - memory/MEMORY.md                (memory index)
#
# Fail-open: never block the commit (we're already post-commit anyway, but
# also never spam the terminal). Runs detached in background so a slow API
# call can't make the commit feel laggy. Output goes to logs/pinecone-sync.log.
# -----------------------------------------------------------------------------

if echo "$FILES_CHANGED" | grep -qE '^(docs/audit/results/|docs/institutional/literature/|docs/runtime/debt-ledger\.md$|memory/MEMORY\.md$)'; then
    LOG_DIR="$SCRIPT_DIR/logs"
    mkdir -p "$LOG_DIR" 2>/dev/null || true
    SYNC_LOG="$LOG_DIR/pinecone-sync.log"
    SYNC_SCRIPT="$SCRIPT_DIR/scripts/tools/sync_pinecone.py"

    if [ -f "$SYNC_SCRIPT" ]; then
        TIMESTAMP=$(date -u +%Y-%m-%dT%H:%M:%SZ)
        {
            echo ""
            echo "=== ${TIMESTAMP} | commit ${SHA} ==="
        } >> "$SYNC_LOG" 2>/dev/null || true

        # Detach: nohup + & + redirected fds so the hook returns immediately
        # even on slow networks. Fail-silent: if nohup is missing (rare on
        # MSYS), fall back to plain background.
        if command -v nohup >/dev/null 2>&1; then
            nohup "$PYTHON" "$SYNC_SCRIPT" >> "$SYNC_LOG" 2>&1 < /dev/null &
        else
            "$PYTHON" "$SYNC_SCRIPT" >> "$SYNC_LOG" 2>&1 < /dev/null &
        fi
        disown 2>/dev/null || true
    fi
fi
